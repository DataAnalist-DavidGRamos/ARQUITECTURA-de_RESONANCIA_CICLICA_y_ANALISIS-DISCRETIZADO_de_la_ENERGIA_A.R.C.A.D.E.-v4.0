{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyMzh2GZ6KO6ow+ugOpjDwdQ"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":1,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"TqqQpZ46N0De","executionInfo":{"status":"ok","timestamp":1771258328119,"user_tz":360,"elapsed":25395,"user":{"displayName":"David Ramos","userId":"01374616962199439815"}},"outputId":"cc930fd2-99cd-4413-e4f5-5dc6bdbe63ac"},"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","✅ Ecosistema ARC conectado a Google Drive.\n"]}],"source":["# =============================================================================\n","# MÓDULO 1: IGNICIÓN ARC v4.0 - CONEXIÓN Y OPTIMIZACIÓN DE MEMORIA\n","# =============================================================================\n","from google.colab import drive\n","import pandas as pd\n","import numpy as np\n","import gc\n","import os\n","\n","# 1. Conexión con el ecosistema de Google\n","def conectar_laboratorio():\n","    drive.mount('/content/drive')\n","    print(\"✅ Ecosistema ARC conectado a Google Drive.\")\n","\n","# 2. Motor de Downcasting (Protección de RAM según Tesis ARC)\n","def optimizar_memoria_arc(df):\n","    \"\"\"Reduce el uso de RAM analizando los límites físicos de cada dato.\"\"\"\n","    memoria_inicial = df.memory_usage().sum() / 1024**2\n","    for col in df.columns:\n","        col_type = df[col].dtype\n","        if col_type != object:\n","            c_min, c_max = df[col].min(), df[col].max()\n","            if str(col_type)[:3] == 'int':\n","                if c_min > np.iinfo(np.int8).min and c_max < np.iinfo(np.int8).max:\n","                    df[col] = df[col].astype(np.int8)\n","                elif c_min > np.iinfo(np.int16).min and c_max < np.iinfo(np.int16).max:\n","                    df[col] = df[col].astype(np.int16)\n","            else:\n","                if c_min > np.finfo(np.float16).min and c_max < np.finfo(np.float16).max:\n","                    df[col] = df[col].astype(np.float16)\n","                elif c_min > np.finfo(np.float32).min and c_max < np.finfo(np.float32).max:\n","                    df[col] = df[col].astype(np.float32)\n","\n","    memoria_final = df.memory_usage().sum() / 1024**2\n","    reduccion = 100 * (memoria_inicial - memoria_final) / memoria_inicial\n","    print(f\"📊 Optimización RAM: {memoria_inicial:.2f}MB -> {memoria_final:.2f}MB (-{reduccion:.1f}%)\")\n","    return df\n","\n","# Ejecutar conexión inicial\n","conectar_laboratorio()"]},{"cell_type":"code","source":["# =============================================================================\n","# MÓDULO 5 (FINAL): ESTABILIZADOR DE DATOS Y RUTA AUTOMÁTICA\n","# =============================================================================\n","import pandas as pd\n","import numpy as np\n","import os\n","import datetime\n","\n","def extraer_comparativa_anual_estable(nombre_archivo):\n","    # 1. Definición de rutas y creación de carpetas\n","    directorio_buzon = '/content/drive/My Drive/bp/COMUNICACION_IA'\n","    if not os.path.exists(directorio_buzon):\n","        os.makedirs(directorio_buzon, exist_ok=True)\n","        print(f\"📁 Carpeta verificada/creada: {directorio_buzon}\")\n","\n","    ruta_archivo = f'/content/drive/My Drive/bt/{nombre_archivo}'\n","    ruta_salida = os.path.join(directorio_buzon, 'COMPARATIVA_FISICA.txt')\n","\n","    # Mapeo manual según RecordTruth del EA v44.70\n","    columnas_arc = ['Timestamp', 'Price', 'N1', 'N2', 'N3', 'N4', 'N5', 'Ups', 'En', 'Sp', 'Score']\n","\n","    print(f\"🔍 Analizando 'La Verdad' con estabilizador en {nombre_archivo}...\")\n","\n","    try:\n","        # Cargamos el primer bloque de 100,000 registros para la comparativa inicial\n","        iter_csv = pd.read_csv(ruta_archivo, sep=';', names=columnas_arc,\n","                               chunksize=100000, low_memory=False, index_col=False)\n","\n","        chunk = next(iter_csv)\n","\n","        # Limpieza de valores críticos\n","        chunk['En'] = pd.to_numeric(chunk['En'], errors='coerce')\n","        chunk['Sp'] = pd.to_numeric(chunk['Sp'], errors='coerce')\n","        chunk = chunk.replace([np.inf, -np.inf], np.nan).dropna(subset=['En', 'Sp'])\n","\n","        # Cálculo de métricas canónicas\n","        avg_en = chunk['En'].mean()\n","        avg_sp = chunk['Sp'].mean()\n","\n","        resumen = f\"\"\"\n","        # REPORTE ARC v4.0 - ESTADO ESTABLE\n","        # GENERADO: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n","\n","        DATOS FÍSICOS DEL SEGMENTO:\n","        - Promedio Energía (En): {avg_en:.8f}\n","        - Promedio Speed (Sp): {avg_sp:.2f} ticks/min\n","\n","        OBSERVACIÓN PARA EL CLÚSTER:\n","        El motor ha mapeado exitosamente las columnas 'En' y 'Sp'.\n","        Este reporte es el 'Buzón' oficial para Claude y DeepSeek.\n","        \"\"\"\n","\n","        with open(ruta_salida, 'w') as f:\n","            f.write(resumen)\n","\n","        print(f\"✅ Reporte guardado con éxito en: {ruta_salida}\")\n","        print(\"\\n--- Muestra de Datos Estables ---\")\n","        print(chunk[['Timestamp', 'En', 'Sp']].tail(5))\n","\n","    except Exception as e:\n","        print(f\"❌ Error en el proceso estable: {e}\")\n","\n","# Ejecución\n","extraer_comparativa_anual_estable('ARC_TRUTH_2020_2026.csv')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Ho7x6Ld8eKpw","executionInfo":{"status":"ok","timestamp":1771262492357,"user_tz":360,"elapsed":258,"user":{"displayName":"David Ramos","userId":"01374616962199439815"}},"outputId":"f3d0fe25-5433-4e87-fe44-e8b233e8d140"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["🔍 Analizando 'La Verdad' con estabilizador en ARC_TRUTH_2020_2026.csv...\n","✅ Reporte guardado con éxito en: /content/drive/My Drive/bp/COMUNICACION_IA/COMPARATIVA_FISICA.txt\n","\n","--- Muestra de Datos Estables ---\n","              Timestamp     En  Sp\n","99995  2020.01.02 04:35  516.0  60\n","99996  2020.01.02 04:35  515.0  60\n","99997  2020.01.02 04:35  516.0  60\n","99998  2020.01.02 04:35  515.0  60\n","99999  2020.01.02 04:35  516.0  60\n"]}]},{"cell_type":"code","source":["import os\n","# Forzar la actualización de la caché de Drive\n","drive.flush_and_unmount()\n","# Volver a montar para asegurar que el archivo sea visible\n","drive.mount('/content/drive')\n","print(\"🔄 Sincronización forzada completada. Revisa la carpeta ahora.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"RqKI37zTeyu6","executionInfo":{"status":"ok","timestamp":1771262658939,"user_tz":360,"elapsed":5417,"user":{"displayName":"David Ramos","userId":"01374616962199439815"}},"outputId":"085dcd93-2608-459a-a9fc-197351f6f26d"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","🔄 Sincronización forzada completada. Revisa la carpeta ahora.\n"]}]},{"cell_type":"code","source":["ruta_reporte = '/content/drive/My Drive/bp/COMUNICACION_IA/COMPARATIVA_FISICA.txt'\n","\n","if os.path.exists(ruta_reporte):\n","    with open(ruta_reporte, 'r') as f:\n","        print(\"📖 CONTENIDO DEL REPORTE (Cópialo para el Enjambre):\\n\")\n","        print(f.read())\n","else:\n","    print(\"❌ El archivo aún no es visible. Verificando directorios...\")\n","    !ls -R \"/content/drive/My Drive/bp/\""],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"goLT_WiefA1O","executionInfo":{"status":"ok","timestamp":1771262712727,"user_tz":360,"elapsed":27,"user":{"displayName":"David Ramos","userId":"01374616962199439815"}},"outputId":"22dede49-e912-4318-f5bb-90719b4e9d7d"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["📖 CONTENIDO DEL REPORTE (Cópialo para el Enjambre):\n","\n","\n","        # REPORTE ARC v4.0 - ESTADO ESTABLE\n","        # GENERADO: 2026-02-16 17:21:47\n","        \n","        DATOS FÍSICOS DEL SEGMENTO:\n","        - Promedio Energía (En): 635.37422000\n","        - Promedio Speed (Sp): 58.25 ticks/min\n","        \n","        OBSERVACIÓN PARA EL CLÚSTER:\n","        El motor ha mapeado exitosamente las columnas 'En' y 'Sp'. \n","        Este reporte es el 'Buzón' oficial para Claude y DeepSeek.\n","        \n"]}]},{"cell_type":"code","source":["# =============================================================================\n","# MÓDULO 6: CÁLCULO DE PERCENTILES CANÓNICOS (AUTO-CALIBRACIÓN)\n","# =============================================================================\n","\n","def calcular_umbrales_canonicos(nombre_archivo):\n","    ruta = f'/content/drive/My Drive/bt/{nombre_archivo}'\n","    columnas_arc = ['Timestamp', 'Price', 'N1', 'N2', 'N3', 'N4', 'N5', 'Ups', 'En', 'Sp', 'Score']\n","\n","    print(f\"🧬 Extrayendo ADN estadístico de {nombre_archivo}...\")\n","\n","    try:\n","        # Cargamos una muestra más grande para tener validez estadística (500k registros)\n","        df_sample = pd.read_csv(ruta, sep=';', names=columnas_arc, nrows=500000, low_memory=False)\n","        df_sample['En'] = pd.to_numeric(df_sample['En'], errors='coerce')\n","        df_sample = df_sample.dropna(subset=['En'])\n","\n","        # Cálculo de Percentiles según Parte 8.2 del Libro Blanco\n","        p20 = np.percentile(df_sample['En'], 20)\n","        p40 = np.percentile(df_sample['En'], 40)\n","        p80 = np.percentile(df_sample['En'], 80)\n","\n","        # Guardar en el buzón para Claude y DeepSeek\n","        ruta_buzon = '/content/drive/My Drive/bp/COMUNICACION_IA/THRESHOLDS_ARC.txt'\n","\n","        reporte_umbrales = f\"\"\"\n","        # REPORTE DE UMBRALES ADAPTATIVOS ARC v4.0\n","        # MUESTRA: 500,000 Registros\n","\n","        VALORES DE CALIBRACIÓN SUGERIDOS:\n","        - P20 (Umbral Reacción/Sniper): {p20:.8f}\n","        - P40 (Umbral Ruptura/Trend Breaker): {p40:.8f}\n","        - P80 (Ruido Extremo): {p80:.8f}\n","\n","        INSTRUCCIÓN:\n","        Claude, usa el P20 como base para el 'Noise Floor' adaptativo.\n","        Si la energía actual es < P20, habilitar protocolo Sniper.\n","        \"\"\"\n","\n","        with open(ruta_buzon, 'w') as f:\n","            f.write(reporte_umbrales)\n","\n","        print(f\"✅ Umbrales calculados y guardados en: {ruta_buzon}\")\n","        print(f\"📊 P20: {p20:.6f} | P40: {p40:.6f} | P80: {p80:.6f}\")\n","\n","    except Exception as e:\n","        print(f\"❌ Error en el cálculo de percentiles: {e}\")\n","\n","calcular_umbrales_canonicos('ARC_TRUTH_2020_2026.csv')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"qe1lEzD7hocq","executionInfo":{"status":"ok","timestamp":1771263398663,"user_tz":360,"elapsed":873,"user":{"displayName":"David Ramos","userId":"01374616962199439815"}},"outputId":"531458d9-77c9-4c25-8d47-06fc1bf5d76e"},"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["🧬 Extrayendo ADN estadístico de ARC_TRUTH_2020_2026.csv...\n","✅ Umbrales calculados y guardados en: /content/drive/My Drive/bp/COMUNICACION_IA/THRESHOLDS_ARC.txt\n","📊 P20: 128.000000 | P40: 262.000000 | P80: 497.000000\n"]}]},{"cell_type":"code","source":["# =============================================================================\n","# MÓDULO 7: RECALIBRACIÓN DE GRADO CERO (UNIFICACIÓN DE ENERGÍA)\n","# =============================================================================\n","import pandas as pd\n","import numpy as np\n","\n","def recalibracion_grado_cero(nombre_archivo):\n","    ruta = f'/content/drive/My Drive/bt/{nombre_archivo}'\n","    # Columnas: Timestamp, Price, N1, N2, N3, N4, N5, Ups, En, Sp, Score\n","\n","    print(\"🔬 Iniciando Recalibración de Grado Cero (Escala 100k)...\")\n","\n","    try:\n","        # Cargamos una muestra de 1M para máxima precisión estadística\n","        df = pd.read_csv(ruta, sep=';', names=['Timestamp', 'Price', 'N1', 'N2', 'N3', 'N4', 'N5', 'Ups', 'En', 'Sp', 'Score'], nrows=1000000)\n","\n","        # UNIFICACIÓN DE FÓRMULA: E = |Delta P| / Delta T * 100,000\n","        # Calculamos sobre el precio bruto para evitar errores de la minería anterior\n","        df['E_Canon'] = df['Price'].diff(3).abs() / 3 * 100000\n","        df = df.dropna()\n","\n","        # Nuevos Percentiles Canónicos\n","        p20 = np.percentile(df['E_Canon'], 20)\n","        p40 = np.percentile(df['E_Canon'], 40)\n","        p80 = np.percentile(df['E_Canon'], 80)\n","\n","        print(f\"\\n✅ RECALIBRACIÓN COMPLETADA (Escala 100k)\")\n","        print(f\"📊 P20 Canónico: {p20:.4f}\")\n","        print(f\"📊 P40 Canónico: {p40:.4f}\")\n","        print(f\"📊 P80 Canónico: {p80:.4f}\")\n","\n","        # Guardar para el Enjambre\n","        with open('/content/drive/My Drive/bp/COMUNICACION_IA/CANON_ENERGY.txt', 'w') as f:\n","            f.write(f\"UNIFICACION ARC v4.0\\nFORMULA: |P-Pn|/n * 100000\\nP20: {p20}\\nP40: {p40}\\nP80: {p80}\")\n","\n","    except Exception as e:\n","        print(f\"❌ Error en recalibración: {e}\")\n","\n","recalibracion_grado_cero('ARC_TRUTH_2020_2026.csv')"],"metadata":{"id":"pGiNV0gmivCS","executionInfo":{"status":"ok","timestamp":1771263688962,"user_tz":360,"elapsed":2115,"user":{"displayName":"David Ramos","userId":"01374616962199439815"}},"outputId":"d64a3822-cc1f-463f-fab7-1685c43bf8cd","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":11,"outputs":[{"output_type":"stream","name":"stdout","text":["🔬 Iniciando Recalibración de Grado Cero (Escala 100k)...\n","\n","✅ RECALIBRACIÓN COMPLETADA (Escala 100k)\n","📊 P20 Canónico: 0.0000\n","📊 P40 Canónico: 666.6667\n","📊 P80 Canónico: 2000.0000\n"]}]}]}